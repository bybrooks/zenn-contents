{
    "name": "Node.js",
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile",
        "args": {
            "NODE_VERSION": "22"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode"
            ]
        }
    },
    "forwardPorts": [
        3000
    ]
}
